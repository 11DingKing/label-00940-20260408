# ===========================================
# E-commerce Microservices 环境配置模板
# ===========================================
# 复制此文件为 .env 并修改敏感信息
# cp .env.example .env

# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=ecommerce

# ==================== JWT 配置 ====================
# 生产环境请使用强随机字符串: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here
JWT_TTL=86400

# ==================== Redis 配置 ====================
REDIS_PASSWORD=

# ==================== Nacos 配置 ====================
NACOS_HOST=nacos
NACOS_PORT=8848
NACOS_GROUP=DEFAULT_GROUP
NACOS_NAMESPACE=

# ==================== 服务端口 ====================
GATEWAY_PORT=8081
USER_SERVICE_PORT=9502
PRODUCT_SERVICE_PORT=9503
ORDER_SERVICE_PORT=9504
INVENTORY_SERVICE_PORT=9505

# ==================== 应用环境 ====================
APP_ENV=production
